# CPDS-AI Environment Variables
# Copy this file to .env and fill in real values
# Never commit .env to git

# ── Anthropic (Claude API) ─────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Beehiiv ────────────────────────────────────────────────────────────────
# API key: Beehiiv dashboard → Settings → API
# Publication ID: visible in dashboard URL after /publications/
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUB_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── GitHub ─────────────────────────────────────────────────────────────────
# Personal access token: https://github.com/settings/tokens
# Scopes needed: public_repo (read only)
GITHUB_TOKEN=ghp_your_token_here

# ── Product Hunt ───────────────────────────────────────────────────────────
# Request at: https://www.producthunt.com/v2/oauth/applications
# Free, takes 1-2 business days to approve
PRODUCTHUNT_API_KEY=your_producthunt_api_key_here

# ── Apify (optional — Tier 2 commercial sources) ───────────────────────────
# Sign up at: https://apify.com — free tier available
# Needed for Fiverr and Upwork scrapers (post-launch)
APIFY_API_TOKEN=your_apify_token_here

# ── Paths ──────────────────────────────────────────────────────────────────
# These default to correct WSL paths — only change if your setup differs
EMIS_DIGEST_PATH=/mnt/d/Projects/emis-exports/digest
CPDS_PROJECT_PATH=/mnt/d/Projects/cpds-ai
