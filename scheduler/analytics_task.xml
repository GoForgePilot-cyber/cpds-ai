<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>CPDS-AI: Pull Beehiiv analytics and write weekly digest. Runs Monday 8am. Output: logs/analytics_YYYY-MM-DD.md</Description>
    <Author>CPDS-AI</Author>
  </RegistrationInfo>
  <Triggers>
    <WeeklyTrigger>
      <StartBoundary>2026-06-22T08:00:00</StartBoundary>
      <ExecutionTimeLimit>PT30M</ExecutionTimeLimit>
      <Enabled>true</Enabled>
      <WeeksInterval>1</WeeksInterval>
      <DaysOfWeek>
        <Monday />
      </DaysOfWeek>
    </WeeklyTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT30M</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>C:\Windows\System32\wsl.exe</Command>
      <Arguments>-e bash -c "cd /mnt/d/Projects/cpds-ai &amp;&amp; ~/venvs/ai-research/bin/python scripts/analytics_digest.py &gt;&gt; logs/scheduler/analytics_$(date +%Y%m%d).log 2&gt;&amp;1"</Arguments>
    </Exec>
  </Actions>
</Task>
